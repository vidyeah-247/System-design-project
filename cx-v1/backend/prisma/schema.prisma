generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Side {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
}

model User {
  id              String      @id @default(uuid())

  username        String      @unique
  password        String

  balances        Balance[]

  orders          Order[]

  buyerFills      Fill[]      @relation("BuyerFills")
  sellerFills     Fill[]      @relation("SellerFills")

  createdAt       DateTime    @default(now())
}

model Balance {
  id              String      @id @default(uuid())

  userId          String
  asset           String

  amount          Float       @default(0)

  user            User        @relation(fields: [userId], references: [id])

  @@unique([userId, asset])
}

model Order {
  id              String        @id @default(uuid())

  userId          String
  market          String

  side            Side

  price           Float
  quantity        Float

  filledQuantity  Float         @default(0)

  status          OrderStatus   @default(OPEN)

  user            User          @relation(fields: [userId], references: [id])

  buyFills        Fill[]        @relation("BuyOrder")
  sellFills       Fill[]        @relation("SellOrder")

  createdAt       DateTime      @default(now())
}

model Fill {
  id              String      @id @default(uuid())

  market          String

  price           Float
  quantity        Float

  buyerId         String
  sellerId        String

  buyerOrderId    String
  sellerOrderId   String

  buyer           User        @relation("BuyerFills", fields: [buyerId], references: [id])

  seller          User        @relation("SellerFills", fields: [sellerId], references: [id])

  buyOrder        Order       @relation("BuyOrder", fields: [buyerOrderId], references: [id])

  sellOrder       Order       @relation("SellOrder", fields: [sellerOrderId], references: [id])

  createdAt       DateTime    @default(now())
}